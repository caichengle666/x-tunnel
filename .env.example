# =============================================================================
# x-tunnel 环境变量配置示例
# 复制为 .env 后填入实际值
# =============================================================================

# 必须：服务端和客户端的认证令牌（双方必须一致）
TOKEN=changeme

# 可选：允许连接的客户端 IP 段（留空表示不限制）
CIDR=0.0.0.0/0,::/0

# 可选：TLS 证书目录（挂载到容器时使用）
CERT_DIR=./certs

# 可选：服务端上游 SOCKS5 代理（多级代理链场景）
SOCKS5_PROXY=
